{
  "name": "ecosign",
  "version": "1.0.0",
  "description": "EcoSign - Document Verification and Signing Platform",
  "main": "index.js",
  "scripts": {
    "dev": "cd client && npm run dev",
    "dev:e2e:visual": "cd client && npm run dev -- --host 127.0.0.1 --port 4173 --strictPort",
    "build": "cd eco-packer && npm install && npm run build && cd ../client && npm install && npm run build",
    "vercel-build": "node scripts/vercel-build.mjs",
    "test": "npm run test:fast",
    "test:fast": "bash scripts/test-fast.sh",
    "test:db": "bash scripts/test-db.sh",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:determinism": "vitest run tests/confidence/core_confidence_invariants.test.ts tests/confidence/extended_confidence_invariants.test.ts tests/authority/protect_document_v2_pipeline_decision.test.ts",
    "test:canonical-e2e": "vitest run tests/canonical-only/complete-pipeline.test.ts",
    "test:event-reconstruction": "vitest run tests/canonical-only/event-reconstruction.test.ts",
    "test:canonical-proof": "vitest run tests/canonical-only/complete-pipeline-proof.test.ts",
    "test:security": "vitest run tests/security/",
    "test:security:watch": "vitest tests/security/",
    "test:e2e:visual": "playwright test -c playwright.visual.config.ts",
    "test:e2e:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
    "release:gate": "bash scripts/release-gate.sh",
    "preview": "cd client && npm run preview",
    "lint": "cd client && npm run lint",
    "lint:fix": "cd client && npm run lint:fix",
    "typecheck": "cd client && npm run typecheck",
    "deadcode": "knip --max-issues 100",
    "validate": "npm run lint && npm run typecheck && npm run test && npm run build",
    "audit:events": "ts-node --project tsconfig.scripts.json --transpile-only scripts/audit-events.ts",
    "diag:progression": "bash scripts/diagnostics/generate-progression-inventory.sh",
    "diag:entrypoint-guard": "bash scripts/diagnostics/check-executor-entrypoints.sh",
    "diag:canonical-readiness": "bash scripts/diagnostics/check-canonical-readiness.sh",
    "diag:decision-path-clean": "bash scripts/diagnostics/check-decision-path-clean.sh",
    "diag:user-documents-freeze-smoke": "bash scripts/diagnostics/smoke-user-documents-freeze.sh",
    "diag:prelaunch-legacy-null-check": "bash scripts/diagnostics/check-prelaunch-legacy-null-entities.sh",
    "diag:internal-runtime-table-hardening": "bash scripts/diagnostics/check-internal-runtime-table-hardening.sh",
    "diag:security-definer-exec-allowlist": "bash scripts/diagnostics/check-security-definer-exec-allowlist.sh",
    "diag:secret-rotation-policy": "bash scripts/diagnostics/check-secret-rotation-policy.sh",
    "diag:invariant-observability": "bash scripts/diagnostics/check-invariant-observability.sh",
    "diag:schema-drift": "bash scripts/diagnostics/check-schema-drift.sh",
    "diag:schema-drift:update-baseline": "bash scripts/diagnostics/check-schema-drift.sh --update",
    "baseline:authority": "bash scripts/diagnostics/snapshot-authority-baseline.sh",
    "baseline:runtime": "bash scripts/diagnostics/baseline-runtime-canonical-smoke.sh",
    "baseline:seal": "npm run baseline:authority && npm run baseline:runtime",
    "governance:build-input": "node scripts/governance/build-input.mjs",
    "check:governance-shadow": "node scripts/governance/run-shadow.mjs",
    "epi:capture-run": "bash scripts/diagnostics/capture-e2e-run.sh",
    "epi:hard-gate": "bash scripts/diagnostics/run-epi-hard-gate.sh",
    "phase1:gate": "npm run diag:entrypoint-guard && npm run diag:canonical-readiness",
    "prod:canonical-switch": "bash scripts/production-canonical-switch.sh",
    "ci:predeploy": "npm run audit:events",
    "sb:start": "supabase start",
    "sb:stop": "supabase stop",
    "sb:status": "supabase status"
  },
  "keywords": [
    "supabase",
    "vercel",
    "nda",
    "document-signing"
  ],
  "author": "Manuel S.",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.81.0",
    "@vercel/analytics": "^1.5.0",
    "jsdom": "^27.2.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^2.7.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "3.11.174"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/jsdom": "^27.0.0",
    "@vitest/coverage-v8": "^4.0.9",
    "@vitest/ui": "^4.0.9",
    "dotenv": "^17.2.3",
    "knip": "^5.73.4",
    "supabase": "^2.58.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.9",
    "yaml": "^2.6.1"
  }
}
